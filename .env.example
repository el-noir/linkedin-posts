# ──────────────────────────────────────────────────────────────────
# LLM auth — two modes (pick one)
# ──────────────────────────────────────────────────────────────────
#
# Mode A — Direct Claude (production):
#   ANTHROPIC_API_KEY=sk-ant-...
#   (leave ANTHROPIC_AUTH_TOKEN and ANTHROPIC_BASE_URL unset)
#
# Mode B — LiteLLM proxy → Vultr → zai-org/GLM-5.2 (default):
#   ANTHROPIC_AUTH_TOKEN=<your-vultr-key>
#   ANTHROPIC_BASE_URL=http://localhost:4000
#   ANTHROPIC_MODEL=zai-org/GLM-5.2
#
# The SDK auto-detects which mode is active. To switch from proxy to
# real Claude: set ANTHROPIC_API_KEY and unset the proxy vars — no code
# changes needed.

# Mode B (uncomment for GLM-5.2 via Vultr/LiteLLM):
ANTHROPIC_AUTH_TOKEN=your-vultr-key-here
ANTHROPIC_BASE_URL=http://localhost:4000
ANTHROPIC_MODEL=zai-org/GLM-5.2

# Mode A (uncomment for direct Claude):
# ANTHROPIC_API_KEY=sk-ant-your-key

# Structured outputs: "auto" tries native output_config.format first,
# then falls back to manual JSON + Zod parse. Set "false" to skip the
# native attempt (saves a round-trip if the proxy is known not to pass it).
# ANTHROPIC_NATIVE_STRUCTURED_OUTPUTS=auto

# ──────────────────────────────────────────────────────────────────
# App
# ──────────────────────────────────────────────────────────────────
NODE_ENV=development
